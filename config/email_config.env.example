# 邮件配置示例
# 复制这份文件为 email_config.env，然后填入你的真实信息

# SMTP 服务器地址
SMTP_SERVER=smtp.163.com

# SMTP 端口（465用SSL，587用TLS）
SMTP_PORT=465

# 发件人邮箱
EMAIL=your_email@163.com

# 邮箱授权码（不是密码！详见 README.md 获取教程）
AUTHORIZATION_CODE=your_16位授权码

# 收件人邮箱（多个用英文逗号分隔）
TO_EMAIL=recipient@example.com

# 抄送邮箱（留空或填写）
CC_EMAIL=
